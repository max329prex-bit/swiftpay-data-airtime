  "mailer_subjects_confirmation": "Verify your BlitzPay account",
  "mailer_subjects_email_change": "Confirm Email Change",
  "mailer_subjects_invite": "You're invited to BlitzPay",
  "mailer_subjects_magic_link": "Sign in to BlitzPay",
  "mailer_subjects_reauthentication": "Your BlitzPay verification code",
  "mailer_subjects_recovery": "Reset your BlitzPay password",
  "mailer_subjects_password_changed_notification": "Your password has been changed",
